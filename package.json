{
  "name": "spaced_repetition_app",
  "author": "Ilya Titov",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/* dev",
    "build": "pnpm -r build",
    "vercel-build": "pnpm --filter spaced_rep_pwa_client build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prisma:generate": "pnpm --filter spaced_rep_pwa_server prisma:generate",
    "prisma:migrate": "pnpm --filter spaced_rep_pwa_server prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter spaced_rep_pwa_server prisma:migrate:deploy",
    "prisma:studio": "pnpm --filter spaced_rep_pwa_server prisma:studio"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "devDependencies": {
    "@types/node": "^25.9.5",
    "tsx": "^4.23.1",
    "typescript": "7.0.2"
  }
}
