# Backend provider: "custom" | "supabase"
# Selected once at build/init — changing requires rebuild.
# If unset: infers custom from VITE_API_URL, else supabase from Supabase vars, else local-only.
VITE_BACKEND_PROVIDER=custom

# --- custom (Express) ---
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=

# --- supabase ---
# VITE_BACKEND_PROVIDER=supabase
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (test sitekey always passes)
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
