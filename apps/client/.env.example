# First-party auth API + Google OAuth (PKCE)
# Sync (HTTP + WebSocket) uses the same VITE_API_URL.
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=

# Legacy Supabase (optional; auth fallback / Apple only — data sync is server-backed)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (test sitekey always passes)
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
