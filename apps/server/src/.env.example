NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Host-side connection (published Docker port). Inside Compose use hostname `postgres`.
DATABASE_URL=postgresql://spaced_rep:spaced_rep@localhost:5433/spaced_rep
REDIS_URL=redis://localhost:6380

# Google OAuth (Web client). Redirect URIs: comma-separated allowlist.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URIS=http://localhost:5173/oauth/google/callback

# Access JWT signing (min 32 chars)
JWT_SECRET=dev-only-change-me-to-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
SESSION_TTL_SECONDS=2592000

# Email OTP (HMAC pepper min 32 chars; use a distinct secret from JWT_SECRET)
OTP_PEPPER=dev-only-change-me-to-a-long-otp-pepper
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Cloudflare Turnstile (test keys always pass: https://developers.cloudflare.com/turnstile/troubleshooting/testing/)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend
RESEND_API_KEY=
EMAIL_FROM=SpacedRep <onboarding@resend.dev>

# WebAuthn / Passkeys (origins: comma-separated exact origins)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SpacedRepApp
WEBAUTHN_ORIGIN=http://localhost:5173
WEBAUTHN_CHALLENGE_TTL_SECONDS=60
