# Postgres
POSTGRES_USER=spaced_rep
POSTGRES_PASSWORD=spaced_rep
POSTGRES_DB=spaced_rep
# Host-published port (internal container port stays 5432)
POSTGRES_PORT=5433

# Redis
# Host-published port (internal container port stays 6379)
REDIS_PORT=6380

# Server
SERVER_PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Service URLs for containers on the Compose network
# Prisma Client (inside the server container) must use hostname `postgres`, not localhost.
DATABASE_URL=postgresql://spaced_rep:spaced_rep@postgres:5432/spaced_rep
REDIS_URL=redis://redis:6379

# Google OAuth + JWT (required by server)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URIS=http://localhost:5173/oauth/google/callback
JWT_SECRET=dev-only-change-me-to-a-long-random-secret

# Email OTP
OTP_PEPPER=dev-only-change-me-to-a-long-otp-pepper
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
RESEND_API_KEY=
EMAIL_FROM=SpacedRep <onboarding@resend.dev>

# Host-side Prisma CLI (run migrate/studio from your machine against published port):
# DATABASE_URL=postgresql://spaced_rep:spaced_rep@localhost:5433/spaced_rep
