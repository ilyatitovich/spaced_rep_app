# Copy to `.env.test` at the repo root before running integration or e2e tests.
# Requires Postgres + Redis (e.g. `pnpm docker:up`) and a dedicated test database:
#   CREATE DATABASE spaced_rep_test;

NODE_ENV=test

# Server
PORT=3000
LOG_LEVEL=error
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://spaced_rep:spaced_rep@localhost:5433/spaced_rep_test
REDIS_URL=redis://localhost:6380/1

JWT_SECRET=test-jwt-secret-at-least-32-characters-long
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
SESSION_TTL_SECONDS=2592000

GOOGLE_CLIENT_ID=test-google-client-id-for-tests-only
GOOGLE_CLIENT_SECRET=test-google-client-secret-for-tests-only
GOOGLE_REDIRECT_URIS=http://localhost:5173/oauth/google/callback

OTP_PEPPER=test-otp-pepper-at-least-32-chars-long
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
RESEND_API_KEY=re_placeholder
EMAIL_FROM=SpacedRep Test <test@example.com>

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SpacedRepApp Test
WEBAUTHN_ORIGIN=http://localhost:5173
WEBAUTHN_CHALLENGE_TTL_SECONDS=60

# Client (Playwright / Vite)
VITE_BACKEND_PROVIDER=custom
VITE_API_URL=http://localhost:3000
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

PLAYWRIGHT_BASE_URL=http://localhost:5173
